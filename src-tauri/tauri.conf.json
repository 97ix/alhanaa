{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tauri-app",
  "version": "1.1.0",
  "identifier": "com.macmasters.tauri-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "فارما تك - نظام إدارة الصيدلية",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
